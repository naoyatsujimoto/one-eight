{
  "rewrites": [
    {
      "source": "/journal-db",
      "destination": "/index.html"
    },
    {
      "source": "/journal-db/",
      "destination": "/index.html"
    },
    {
      "source": "/journal-db/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/journal",
      "destination": "/index.html"
    },
    {
      "source": "/journal/",
      "destination": "/index.html"
    },
    {
      "source": "/journal/:path*",
      "destination": "/index.html"
    }
  ]
}
